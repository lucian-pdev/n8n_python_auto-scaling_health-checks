# ============================================
# N8N Configuration - PRODUCTION
# ============================================
N8N_HOST=n8n.yourdomain.com
WEBHOOK_URL=https://n8n.yourdomain.com
N8N_PROTOCOL=https
N8N_SECURE_COOKIE=True

# Security
N8N_BASIC_AUTH_USER=your_secure_admin
N8N_BASIC_AUTH_PASSWORD=your_strong_password_here
N8N_ENCRYPTION_KEY=your_32_byte_hex_key_here

# Port Bindings (localhost only - behind nginx)
N8N_PUBLISHED_PORT=127.0.0.1:5678:5678
GRAFANA_PUBLISHED_PORT=127.0.0.1:3000:3000
PROMETHEUS_PUBLISHED_PORT=127.0.0.1:9090:9090
CADVISOR_PUBLISHED_PORT=127.0.0.1:8080:8080
NODE_EXPORTER_PUBLISHED_PORT=127.0.0.1:9100:9100
PYTHON_API_PUBLISHED_PORT=127.0.0.1:8000:8000

# Grafana
GF_SECURITY_ADMIN_USER=your_secure_admin
GF_SECURITY_ADMIN_PASSWORD=your_strong_password_here

# Redis
REDIS_PASSWORD=your_strong_redis_password