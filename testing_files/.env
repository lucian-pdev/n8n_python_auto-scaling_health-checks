# ============================================
# N8N Configuration - TESTING (not exposed to network outside host computer)
# ============================================
N8N_HOST=192.168.0.100      # watch out for DHCP assigned IP
WEBHOOK_URL=http://192.168.0.100:5678   # DHCP warning here too
N8N_PROTOCOL=http
N8N_SECURE_COOKIE=False

# Security (relaxed for local testing)
N8N_BASIC_AUTH_USER=admin@local.com
N8N_BASIC_AUTH_PASSWORD=pass
N8N_ENCRYPTION_KEY=a2ac75ab0d0f6798b16a61da518ba1f3d75e205f7560c312257911e90c7476b5

# Port Bindings (exposed to VM network)
N8N_PUBLISHED_PORT=5678:5678
GRAFANA_PUBLISHED_PORT=3000:3000
PROMETHEUS_PUBLISHED_PORT=9090:9090
CADVISOR_PUBLISHED_PORT=8080:8080
NODE_EXPORTER_PUBLISHED_PORT=9100:9100
PYTHON_API_PUBLISHED_PORT=8000:8000

# Grafana
GF_SECURITY_ADMIN_USER=admin
GF_SECURITY_ADMIN_PASSWORD=pass

# Redis (no password for testing)
REDIS_PASSWORD=